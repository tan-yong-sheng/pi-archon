{
  "name": "@saber7ooth/pi-archon",
  "version": "0.0.8",
  "description": "Archon workflow extension package for Pi coding agent",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./archon": "./src/archon.ts"
  },
  "files": [
    "src",
    "assets"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "archon",
    "workflow",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/loopyd/pi-archon.git"
  },
  "homepage": "https://github.com/loopyd/pi-archon#readme",
  "bugs": {
    "url": "https://github.com/loopyd/pi-archon/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.6.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "./assets/logo.png"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && pnpm pack --dry-run"
  },
  "dependencies": {
    "typebox": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
